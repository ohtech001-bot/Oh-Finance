{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "SKIP_PRISMA_GENERATE=1 npm install --include=dev",
  "buildCommand": "cd ../.. && npm run build:web",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}