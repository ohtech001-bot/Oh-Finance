{
  "extends": "@oh/typescript-config/node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "strictPropertyInitialization": false,
    "noUnusedParameters": false,

    "composite": false,
    "incremental": true,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "prisma/seed.ts",
    "src/**/*.test.ts"
  ]
}