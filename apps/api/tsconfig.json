{
  "extends": "@oh/typescript-config/node.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "strictPropertyInitialization": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test", "prisma/seed.ts", "src/**/*.test.ts"],
  "references": [
    { "path": "../../packages/money" },
    { "path": "../../packages/config" },
    { "path": "../../packages/contracts" }
  ]
}
