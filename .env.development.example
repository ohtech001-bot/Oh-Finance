# =============================================================================
#  Oh-Finance — بيئة التطوير (TEMPLATE)
#  انسخه إلى .env.development وضع القيم الحقيقية.  ⛔ لا أسرار هنا.
# =============================================================================

NODE_ENV=development
API_PORT=3001
API_HOST=127.0.0.1
WEB_ORIGIN=http://localhost:5173
LOG_LEVEL=debug

# ── قاعدة بيانات التطوير ─────────────────────────────────────────────────────
# ضع رابط Neon الخاص بك هنا محليًا. مثال على الشكل فقط (ليس قيمة صالحة):
#   DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
#   DIRECT_DATABASE_URL=postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL=
DIRECT_DATABASE_URL=

REDIS_URL=

# ولّد كل سر بأمر:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
COOKIE_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10
AUTH_LOCKOUT_THRESHOLD=10
AUTH_LOCKOUT_MINUTES=15

DEFAULT_LOCALE=ar
DEFAULT_CURRENCY=ILS
DEFAULT_TIMEZONE=Asia/Jerusalem

FEATURE_2FA=false
FEATURE_MESSAGING=false
FEATURE_PRODUCTS=false

# ── بذور البيانات (seed) — للتطوير فقط ───────────────────────────────────────
# تُستخدم مرة واحدة لإنشاء المدير العام وصاحب المحل. غيّر كلمة المرور فورًا.
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
