# =============================================================================
#  Oh-Finance — Environment Variables (TEMPLATE)
# =============================================================================
#  انسخ هذا الملف إلى .env.development أو .env وضع القيم الحقيقية محليًا.
#  ⛔ لا تضع أي قيمة حقيقية في هذا الملف ولا ترفع .env إلى git.
#  التحقق من هذه المتغيرات يتم بـ Zod عند إقلاع الخادم (fail-fast).
# =============================================================================

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3001
API_HOST=127.0.0.1
WEB_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────────────────────
# DATABASE_URL         : اتصال تشغيلي عبر pooler (PgBouncer). يستخدمه التطبيق.
# DIRECT_DATABASE_URL  : اتصال مباشر بلا pooler. تستخدمه الهجرات فقط.
#                        (Prisma migrate لا يعمل عبر pooler في وضع transaction)
# الشكل: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=
DIRECT_DATABASE_URL=

# ── Redis (طوابير BullMQ + تخزين حدود المعدل) ────────────────────────────────
# الشكل: rediss://default:PASSWORD@HOST:PORT
REDIS_URL=${{Redis.REDIS_URL}}

# ── Authentication ───────────────────────────────────────────────────────────
# ولّد أسرارًا بـ:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# ⛔ الحد الأدنى 32 حرفًا. أسرار مختلفة لكل بيئة.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
COOKIE_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── Cookies ──────────────────────────────────────────────────────────────────
# COOKIE_SECURE=true إلزامي في الإنتاج (HTTPS فقط)
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=5
AUTH_LOCKOUT_THRESHOLD=10
AUTH_LOCKOUT_MINUTES=15

# ── Localization & Money ─────────────────────────────────────────────────────
DEFAULT_LOCALE=ar
DEFAULT_CURRENCY=ILS
DEFAULT_TIMEZONE=Asia/Jerusalem

# ── Feature flags ────────────────────────────────────────────────────────────
FEATURE_2FA=false
FEATURE_MESSAGING=false
FEATURE_PRODUCTS=false

# ── Outgoing email (company mailbox) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@oh-tech.co
SMTP_PASSWORD=
SMTP_FROM_EMAIL=info@oh-tech.co
SMTP_FROM_NAME=OH Finance
