# =============================================================================
#  Oh-Finance — بيئة الاختبارات (TEMPLATE)
#  انسخه إلى .env.test وضع القيم الحقيقية.  ⛔ لا أسرار هنا.
#
#  ⚠️  استخدم قاعدة بيانات مستقلة تمامًا عن التطوير.
#      اختبارات التكامل تُفرّغ الجداول (TRUNCATE) بين الحالات.
#      توجيهها إلى قاعدة التطوير يمسح بياناتك.
# =============================================================================

NODE_ENV=test
API_PORT=3002
WEB_ORIGIN=http://localhost:5173
LOG_LEVEL=silent

# ── قاعدة بيانات الاختبار (منفصلة!) ──────────────────────────────────────────
# TEST_DATABASE_URL هو المتغير الذي تقرأه اختبارات التكامل.
# إن كان فارغًا: تتخطى اختبارات التكامل بأمان مع رسالة واضحة (لا تفشل).
TEST_DATABASE_URL=
TEST_DIRECT_DATABASE_URL=

# Redis اختياري للاختبارات — إن غاب تُستخدم حدود معدل بالذاكرة.
REDIS_URL=

# أسرار اختبار — ثابتة ومعروفة، لا قيمة أمنية لها. ولّد أي قيمة ≥32 حرفًا.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
COOKIE_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# حدود مرتفعة حتى لا تُفشل الاختباراتُ نفسَها
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=10000
AUTH_RATE_LIMIT_MAX=1000
AUTH_LOCKOUT_THRESHOLD=1000
AUTH_LOCKOUT_MINUTES=1

DEFAULT_LOCALE=ar
DEFAULT_CURRENCY=ILS
DEFAULT_TIMEZONE=Asia/Jerusalem

FEATURE_2FA=true
FEATURE_MESSAGING=false
FEATURE_PRODUCTS=false
